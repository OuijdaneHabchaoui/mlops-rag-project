# ============================================================================
# MLOps_RAG_Project — .gitignore enterprise-grade
# ============================================================================

# --- Secrets & credentials (CRITIQUE — ne jamais commit) ---
.env
.env.*
!.env.example
*.pem
*.key
*credentials*
*secret*

# --- Python ---
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg

# --- Environnements virtuels ---
.venv/
venv/
env/
ENV/
.python-version

# --- IDE & éditeurs ---
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# --- Tests & coverage ---
.pytest_cache/
.coverage
.coverage.*
htmlcov/
.tox/
.nox/
coverage.xml
*.cover
.hypothesis/

# --- Type checking ---
.mypy_cache/
.dmypy.json
.pyre/
.pytype/
.ruff_cache/

# --- Jupyter ---
.ipynb_checkpoints/
*.ipynb_checkpoints/

# --- MLflow tracking (local, ne pas commit) ---
mlruns/
mlartifacts/
mlflow.db
mlflow.db-journal
mlflow.db.OLD*

# --- Logs & runs ---
logs/
*.log
experiments/runs/

# --- Artifacts générés ---
test_artifact.txt
reports/*/
!reports/.gitkeep
**/*.html
**/*.pdf

# --- Docker ---
.docker/
docker-compose.override.yml

# --- Backups ---
*.backup
*.bak
*.old
*.OLD*

# --- OS files ---
.DS_Store
.AppleDouble
.LSOverride
Thumbs.db
ehthumbs.db
Desktop.ini

# --- Outils sécurité ---
.bandit_report.json
# --- Travail personnel (non public) ---
ROADMAP.md
docs/rapport_experimentations.md

# ============================================================================
# Template de configuration — copier vers .env et remplir les valeurs
# IMPORTANT : .env est dans .gitignore — ne JAMAIS commit les vraies cles
# ============================================================================

# --- MLflow (LOCAL via start_mlflow.bat) -----------------------------------
MLFLOW_TRACKING_URI=http://127.0.0.1:5000

# --- Langfuse (CLOUD — gratuit jusqu'a 50k traces/mois) --------------------
# Setup (5 min) :
#   1. Aller sur https://cloud.langfuse.com -> Sign up
#   2. New Project -> "MLOps_RAG_CDG"
#   3. Settings -> API Keys -> Create new keys
#   4. Coller les 2 cles ci-dessous (laisser LANGFUSE_HOST tel quel)

LANGFUSE_PUBLIC_KEY=pk-lf-xxxxxxxxxxxxxxxxxxxxxxxx
LANGFUSE_SECRET_KEY=sk-lf-xxxxxxxxxxxxxxxxxxxxxxxx
LANGFUSE_HOST=https://cloud.langfuse.com

# --- Mistral API (LLM + embeddings + OCR) ----------------------------------
# Reutiliser la meme cle que dans le projet shipping/.env
MISTRAL_API_KEY=

# --- HuggingFace (modeles bge-reranker, etc.) ------------------------------
HF_TOKEN=
